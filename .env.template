# ============================================================
# LLM Provider — pick one set and uncomment/configure it.
# The pipeline reads these on every startup.
# ============================================================

# ---- OpenAI (original) ----
# OPENAI_API_KEY="sk-..."
# LLM_MODEL="gpt-4o-mini"
# LLM_TIMEOUT=120

# ---- OpenRouter (free tier) ----
# OPENAI_API_KEY="sk-or-v1-..."
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# LLM_MODEL="nvidia/nemotron-3-super-120b-a12b:free"
# LLM_TIMEOUT=120

# ---- Groq (fast, free tier) ----
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# LLM_MODEL="mixtral-8x7b-32768"
# LLM_TIMEOUT=300

# ---- Azure OpenAI ----
# OPENAI_API_KEY="your-azure-key"
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview"
# LLM_MODEL="gpt-4o"
# LLM_TIMEOUT=120

# ============================================================
# LangSmith Tracing (optional — uncomment to enable)
# Get your API key at https://smith.langchain.com
# ============================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=etl-enrichment-pipeline
